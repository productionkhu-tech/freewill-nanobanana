# NanoBanana - API keys (macOS)
#
# HOW TO USE
#   1) Make a copy of this file named exactly:  keys.env
#   2) Fill in the values you have (leave the others blank).
#   3) Save, then double-click start_mac.command.
#
# keys.env holds your private keys - never share it or commit it to git.
# (It is already in .gitignore.)

# --- Google Gemini via Vertex AI (optional) ---
# Put your Vertex service-account JSON file in THIS folder and write its file
# name below (e.g. vertex-key.json). Then set your Google Cloud project id.
GOOGLE_APPLICATION_CREDENTIALS=vertex-key.json
NANOBANANA_PROJECT_ID=
NANOBANANA_LOCATION=global

# --- Google Gemini via AI Studio (optional, simplest) ---
# A single API key from https://aistudio.google.com/apikey
NANOBANANA_STUDIO_KEY=

# --- OpenAI (optional, only needed for the gpt-image-2 model) ---
OPENAI_API_KEY=

# --- App behaviour (optional) ---
# Auto-update fetches the latest version on launch (only when installed via
# git clone). Uncomment the next line and set 0 to turn it OFF.
# NANOBANANA_AUTO_UPDATE=0
